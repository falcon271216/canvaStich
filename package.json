{
  "name": "excalidraw",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "pnpm --filter @repo/db run db:migrate",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    "postinstall": "pnpm exec prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "prisma": "6.10.1",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
