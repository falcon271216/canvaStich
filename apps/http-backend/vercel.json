{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=http-backend...",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/vercel-app.cjs"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
