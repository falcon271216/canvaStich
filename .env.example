# =============================================================================
# SketchUI — one repo, four deployments (see DEPLOY.md)
# =============================================================================

# --- Shared (http-backend + ws-backend on Railway) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
JWT_SECRET="replace-with-long-random-secret-min-32-chars"

# --- http-backend (Vercel: apps/http-backend) ---
GEMINI_API_KEY="your-google-gemini-api-key"
GEMINI_MODEL="gemini-3.5-flash"
WEB_APP_URL="https://your-web.vercel.app"
DASHBOARD_URL="https://your-dashboard.vercel.app"

# --- web (Vercel: apps/web) ---
NEXT_PUBLIC_HTTP_API="https://your-api.vercel.app"
NEXT_PUBLIC_WS_URL="wss://your-ws.up.railway.app"
NEXT_PUBLIC_DASHBOARD_URL="https://your-dashboard.vercel.app"

# --- dashboard (Vercel: apps/dashboard) ---
# NEXT_PUBLIC_HTTP_API="https://your-api.vercel.app"
