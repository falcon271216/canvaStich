# =============================================================================
# SketchUI — environment variables (see DEPLOY.md for full deployment guide)
# Copy to `.env` at repo root for local development.
# =============================================================================

# --- Shared: API (Vercel) + WebSocket (Railway) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
JWT_SECRET="replace-with-long-random-secret-min-32-chars"

# --- Vercel: apps/http-backend ---
GEMINI_API_KEY="your-google-gemini-api-key"
WEB_APP_URL="https://your-web.vercel.app"
DASHBOARD_URL="https://your-dashboard.vercel.app"

# --- Vercel: apps/web ---
NEXT_PUBLIC_HTTP_API="https://your-api.vercel.app"
NEXT_PUBLIC_WS_URL="wss://your-ws.up.railway.app"
NEXT_PUBLIC_DASHBOARD_URL="https://your-dashboard.vercel.app"

# --- Vercel: apps/dashboard ---
NEXT_PUBLIC_HTTP_API="https://your-api.vercel.app"
NEXT_PUBLIC_WS_METRICS="https://your-ws.up.railway.app/metrics"
# NEXT_PUBLIC_PROMETHEUS_URL="http://localhost:9090"
